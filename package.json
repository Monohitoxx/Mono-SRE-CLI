{
  "name": "sre-ai",
  "version": "0.1.0",
  "description": "SRE AI - DevOps & Infrastructure CLI powered by AI",
  "type": "module",
  "bin": {
    "sre-ai": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx/esm --test tests/unit/risk-classifier.test.ts tests/unit/settings.test.ts tests/unit/command-policy.test.ts tests/integration/agent-gates.test.ts tests/integration/prompt-injection.test.ts",
    "test:e2e": "node --import tsx/esm --test tests/e2e/prompt-injection-real.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "latest",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.7",
    "ink": "^5.1.0",
    "ink-gradient": "^3.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "meow": "^13.0.0",
    "openai": "latest",
    "react": "^18.3.1",
    "ssh2": "^1.16.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/ssh2": "^1.15.0",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
