# --- OpenAI ---
# PROVIDER=openai
# MODEL=gpt-4o
# APIKEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Anthropic ---
# PROVIDER=anthropic
# MODEL=claude-sonnet-4-20250514
# APIKEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# --- vLLM / Local Model (OpenAI compatible) ---
PROVIDER=openai
MODEL=your-model-name
APIKEY=
API_BASE_URL=http://localhost:8000/v1

# ─── Generation Parameters ───────────────────────────────────
# All optional. If not set, uses provider defaults.
# These are passed directly to the API call.
#
# TEMPERATURE   - Sampling randomness (0=greedy, 2=max random)
#                 Qwen3 recommended: 0.7 for tool calling
# TOP_P         - Nucleus sampling threshold (0-1)
#                 Qwen3 recommended: 0.8
# TOP_K         - Top-k sampling (-1=all tokens)
#                 vLLM only, passed via extra_body
# MAX_TOKENS    - Max tokens to generate per response
#                 Default: 4096 (vLLM default is only 16!)
# REPETITION_PENALTY - Penalize repeated tokens (>1 = less repetition)
#                 Qwen3 recommended: 1.05. vLLM only, passed via extra_body
# FREQUENCY_PENALTY  - Penalize tokens by frequency in output (-2 to 2)
# PRESENCE_PENALTY   - Penalize tokens by presence in output (-2 to 2)
# SEED          - Fixed random seed for reproducibility
#
# TEMPERATURE=0.7
# TOP_P=0.8
# MAX_TOKENS=4096
# REPETITION_PENALTY=1.05
# FREQUENCY_PENALTY=0.0
# PRESENCE_PENALTY=0.0
# TOP_K=-1
# SEED=42
